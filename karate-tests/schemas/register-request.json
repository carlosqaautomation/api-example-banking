{
  "type": "object",
  "required": ["email", "password", "fullName"],
  "properties": {
    "email": {
      "type": "string",
      "format": "email"
    },
    "password": {
      "type": "string",
      "minLength": 6,
      "maxLength": 20
    },
    "fullName": {
      "type": "string",
      "minLength": 2,
      "maxLength": 100
    },
    "phone": {
      "type": "string",
      "pattern": "^\\+?[1-9]\\d{1,14}$"
    }
  }
}